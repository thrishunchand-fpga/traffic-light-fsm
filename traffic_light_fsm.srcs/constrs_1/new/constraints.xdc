## CLOCK
set_property PACKAGE_PIN H16 [get_ports clk]
set_property IOSTANDARD LVCMOS33 [get_ports clk]

## RESET (example button)
set_property PACKAGE_PIN D19 [get_ports rst]
set_property IOSTANDARD LVCMOS33 [get_ports rst]

## RED LED
set_property PACKAGE_PIN R14 [get_ports red]
set_property IOSTANDARD LVCMOS33 [get_ports red]

## YELLOW LED
set_property PACKAGE_PIN P14 [get_ports yellow]
set_property IOSTANDARD LVCMOS33 [get_ports yellow]

## GREEN LED
set_property PACKAGE_PIN N16 [get_ports green]
set_property IOSTANDARD LVCMOS33 [get_ports green]